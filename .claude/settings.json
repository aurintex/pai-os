{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "outputStyle": "concise",
  "permissions": {
    "allow": [],
    "deny": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/agent_hooks.sh format-rust 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/agent_hooks.sh validate-tasks 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
